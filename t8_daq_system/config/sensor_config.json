            "auto_shutoff": true,
            "warning_threshold": 0.9,
            "debounce_count": 3
        }
    },
    "logging": {
        "interval_ms": 100,
        "file_prefix": "data_log",
        "auto_start": false
    },
    "display": {
        "update_rate_ms": 100,
        "history_seconds": 60
    }
